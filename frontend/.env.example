# ============================================================
# SmartVenue Frontend вЂ” Environment Variables
# Copy this file to `.env.development` (local) or `.env.production` (production).
# NEVER commit actual .env files with real keys.
# ============================================================

# --- Backend API URL ---
# Local dev: http://localhost:8000
# Production: https://your-cloud-run-url.run.app
VITE_API_URL=http://localhost:8000

# --- Supabase (Frontend) ---
# Your Supabase project URL (Dashboard в†’ Settings в†’ API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# вљ пёЏ IMPORTANT: Use the ANON key here, NEVER the service_role key!
# The anon key is safe for browsers. The service_role key bypasses RLS.
# Dashboard в†’ Settings в†’ API в†’ anon (public)
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key-only

# --- Google Maps ---
# JavaScript API Key вЂ” restrict this to your domain in GCP Console!
# Enable: Maps JavaScript API, Places API
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...your-maps-api-key
