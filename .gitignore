# ============================================================
# SMARTVENUE .gitignore — Security & Size Hardened
# ============================================================

# --- SECURITY: ALL SECRETS & KEYS (NEVER COMMIT) ---
secrets/
.env
.env.*
.env.development
.env.production
.env.local
*.local
env_vars.yaml

# --- LARGE MODEL FILES (use GCS, not Git) ---
*.pkl
*.pickle
*.h5
*.pt
*.pth
*.onnx
*.gguf
backend/app/resources/wait_time_model.pkl

# --- LARGE DATA FILES ---
hero_patterns.json
backend/app/resources/hero_patterns.json

# --- JSON (except config files) ---
*.json
!package.json
!package-lock.json
!tsconfig.json
!tsconfig.app.json
!tsconfig.node.json
!hitex_calibration_*.json
!composer.json

# --- SYSTEM & OS ---
.DS_Store
Thumbs.db
*.swp
*.log

# --- PYTHON ---
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# --- NODE / FRONTEND ---
node_modules/
.next/
dist/
build/
.cache/

# --- AI & AGENTS ---
.agents/
.gemini/
*.zip
plan/
scratch/
walkthrough/
task.md
implementation_plan.md
research_notes.md
system_audit.md
[ARTIFACT]*

data/