# ============================================================
# SmartVenue Backend — Environment Variables
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the actual .env file.
# ============================================================

# --- Supabase ---
# Your Supabase project URL (Dashboard → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase SERVICE ROLE key (backend only, never expose to frontend)
# Dashboard → Settings → API → service_role (secret)
SUPABASE_KEY=eyJhbGci...your-service-role-key

# Anon key (for public/unauthenticated operations)
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# JWT secret for verifying user tokens (Dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Google Cloud / Vertex AI ---
# GCP Project ID (used for Vertex AI Gemini access)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Maps JavaScript API Key (backend key, browser-restricted recommended)
GOOGLE_MAPS_API_KEY=AIzaSy...your-maps-api-key

# --- Optional: Gemini Direct API (if not using Vertex AI) ---
# GEMINI_API_KEY=AIzaSy...your-gemini-direct-key

# --- App Settings ---
ENVIRONMENT=development
CACHE_TTL_SECONDS=30
RATE_LIMIT_PER_MINUTE=20

# --- Optional: Alert Webhook ---
# URL to receive mission-critical congestion alerts (e.g. Slack, Discord webhook)
# WEBHOOK_URL=https://hooks.slack.com/services/...
